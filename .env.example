# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/bluefairy?sslmode=disable

# Auth
JWT_SECRET=your-very-secure-jwt-secret-key-here

# Server
PORT=8000

# Optional – proxy auth
# PROXY_SECRET=shared-secret-with-proxy

# Optional – tenant provisioning
# TENANT_PROVISIONER_URL=http://localhost:8081
# TENANT_BASE_URL=https://{name}.wareit.ai
# TENANT_HOST_TEMPLATE={name}.internal.wareit.ai

# Google OAuth (for Gmail, Calendar, Drive connections)
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-your-secret
# GOOGLE_REDIRECT_URI=https://api.wareit.ai/oauth/google/callback
